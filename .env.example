# llm-market-data-agent runs WITHOUT any key: the data tools (Binance, DeFiLlama) are
# free and keyless, and the Claude call is gated behind ANTHROPIC_API_KEY with a
# committed cached fallback, so the notebook executes end-to-end with nothing set.
#
# Set this ONLY if you want the agent to call Claude live (it is optional). Copy this
# file to .env, paste your key, and the keyed cells will run for real instead of using
# the cached example response.

# ANTHROPIC_API_KEY=sk-ant-...

# Optional: point the data tools at a different Binance base URL (e.g. a regional mirror).
# BINANCE_BASE_URL=https://api.binance.com
